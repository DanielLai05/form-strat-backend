# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Vite dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string used by the pg driver
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/form_strat"

# Anthropic API key — powers AI form generation, field suggestions, and analytics.
# Get one at https://console.anthropic.com/. AI endpoints return 503 without it.
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for AI features.
AI_MODEL=claude-opus-4-8
