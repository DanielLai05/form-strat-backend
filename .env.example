# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Vite dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string used by the pg driver
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/form_strat"

# OpenRouter API key — powers AI form generation, field suggestions, and analytics.
# Get one at https://openrouter.ai/keys. AI endpoints return 503 without it.
OPENROUTER_API_KEY=
# OpenRouter model id (provider/model). Must support structured outputs.
# Examples: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-sonnet-4
AI_MODEL=openai/gpt-4o-mini
# Optional: your app URL, sent to OpenRouter as HTTP-Referer for attribution.
APP_URL=http://localhost:5173
